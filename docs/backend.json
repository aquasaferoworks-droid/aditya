
{
  "entities": {
    "Video": {
      "title": "Video",
      "description": "A cinematic video project entry.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "array", "items": { "type": "string" } },
        "youtubeId": { "type": "string" },
        "type": { 
          "type": "string", 
          "enum": ["slider", "reel-horizontal", "reel-feature", "reel-medium", "reel-vertical", "sidebar"] 
        },
        "upperText": { "type": "string" },
        "lowerText": { "type": "string" },
        "meta": { "type": "string" },
        "award": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["youtubeId", "type"]
    },
    "ContactSettings": {
      "title": "Contact Settings",
      "description": "Global settings for contact information and social links.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "representation": { "type": "string" },
        "locations": { "type": "string" },
        "formHeading": { "type": "string" },
        "formDescription": { "type": "string" },
        "instagram": { "type": "string" },
        "youtube": { "type": "string" },
        "whatsapp": { "type": "string" },
        "facebook": { "type": "string" },
        "twitter": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/videos/{videoId}": {
      "schema": "Video",
      "description": "Collection of all video projects."
    },
    "/settings/contact": {
      "schema": "ContactSettings",
      "description": "Single document for global contact settings."
    }
  }
}
